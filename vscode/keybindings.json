[
  // ==============================================
  // Navigation (Ctrl+W)
  // ==============================================
  { "key": "ctrl+w h", "command": "workbench.action.navigateLeft" },
  { "key": "ctrl+w l", "command": "workbench.action.navigateRight" },
  { "key": "ctrl+w j", "command": "workbench.action.navigateDown" },
  { "key": "ctrl+w k", "command": "workbench.action.navigateUp" },

  // ==============================================
  // Explorer Actions
  // ==============================================
  { "key": "a", "command": "explorer.newFile", "when": "filesExplorerFocus && !inputFocus" },
  { "key": "shift+a", "command": "explorer.newFolder", "when": "filesExplorerFocus && !inputFocus" },
  { "key": "r", "command": "renameFile", "when": "filesExplorerFocus && !inputFocus" },
  { "key": "y", "command": "filesExplorer.copy", "when": "filesExplorerFocus && !inputFocus" },
  { "key": "p", "command": "filesExplorer.paste", "when": "filesExplorerFocus && !inputFocus" },
  { "key": "d", "command": "deleteFile", "when": "filesExplorerFocus && !inputFocus" },
  {
    "key": "ctrl+[",
    "command": "workbench.action.closeSidebar",
    "when": "(filesExplorerFocus && !inputFocus) || searchViewletFocus || scmViewletFocus || extensionsViewletFocus || debugViewletFocus || problemsViewletFocus"
  },
  {
    "key": "escape",
    "command": "workbench.action.closeSidebar",
    "when": "(filesExplorerFocus && !inputFocus) || searchViewletFocus || scmViewletFocus || extensionsViewletFocus || debugViewletFocus || problemsViewletFocus"
  },
  {
    "key": "enter",
    "command": "-renameFile",
    "when": "filesExplorerFocus && foldersViewVisible && !explorerResourceIsRoot && !explorerResourceReadonly && !inputFocus"
  },

  // ==============================================
  // List/QuickOpen Navigation
  // ==============================================
  { "key": "ctrl+n", "command": "list.focusDown", "when": "listFocus" },
  { "key": "ctrl+p", "command": "list.focusUp", "when": "listFocus" },
  { "key": "ctrl+n", "command": "workbench.action.quickOpenSelectNext", "when": "inQuickOpen" },
  { "key": "ctrl+p", "command": "workbench.action.quickOpenSelectPrevious", "when": "inQuickOpen" },
  { "key": "ctrl+[", "command": "workbench.action.closeQuickOpen", "when": "inQuickOpen" },
  { "key": "escape", "command": "workbench.action.closeQuickOpen", "when": "inQuickOpen" },

  // =============================================
  // Search & Problems
  // =============================================
  { "key": "ctrl+n", "command": "search.action.focusSearchList", "when": "searchViewletVisible && (searchInputBoxFocus || replaceInputBoxFocus)" },
  { "key": "ctrl+n", "command": "list.focusDown", "when": "searchViewletFocus && !inputFocus" },
  { "key": "ctrl+p", "command": "list.focusUp", "when": "searchViewletFocus && !inputFocus" },
  { "key": "ctrl+p", "command": "search.action.focusSearchFromResults", "when": "replaceInputBoxFocus" },
  { "key": "ctrl+r", "command": "workbench.action.replaceInFiles", "when": "searchInputBoxFocus || searchViewletFocus" },
  { "key": "/", "command": "search.action.focusSearchFromResults", "when": "searchViewletFocus && !inputFocus" },
  { "key": "ctrl+; r", "command": "search.action.replaceAll", "when": "replaceActive && searchViewletVisible && !findWidgetVisible" },
  { "key": "ctrl+; l", "command": "search.action.replaceAllInFile", "when": "fileMatchFocus && isEditableItem && replaceActive && searchViewletVisible" },
  { "key": "/", "command": "problems.action.focusFilter", "when": "problemFocus && !inputFocus" },
  { "key": "ctrl+n", "command": "list.focusDown", "when": "problemsFilterFocus" },
  { "key": "ctrl+p", "command": "list.focusUp", "when": "problemsFilterFocus" },
  { "key": "ctrl+[", "command": "workbench.actions.view.toggleProblems", "when": "problemsFilterFocus" },
  { "key": "escape", "command": "workbench.actions.view.toggleProblems", "when": "problemsFilterFocus" },
  { "key": "escape", "command": "workbench.action.closePanel", "when": "panelFocus" }
]