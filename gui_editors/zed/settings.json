{
  // ===============================================
  // Vim
  // ===============================================
  "vim_mode": true,
  "vim": {
    "cursor_shape": {
      "normal": "block",
      "insert": "bar",
      "replace": "hollow",
      "visual": "underline",
    },
  },
  // ===============================================
  // Editor
  // ===============================================
  "buffer_font_weight": 500.0,
  "cursor_shape": "block",
  "preview_tabs": {
    "enabled": false,
  },
  "format_on_save": "off",
  "scrollbar": null,
  "tab_bar": {
    "show": false,
  },
  "gutter": {
    "line_numbers": true,
  },
  "minimap": {
    "show": "never",
  },
  "cursor_blink": false,
  "colorize_brackets": true,
  // ===============================================
  // Git
  // ===============================================
  "git": {
    "inline_blame": {
      "enabled": false,
    },
    "git_gutter": "hide",
    "disable_git": true,
  },
  "project_panel": {
    "git_status": false,
  },
  "outline_panel": {
    "git_status": false,
  },
  "tabs": {
    "git_status": false,
  },
  // ===============================================
  // LSP
  // ===============================================
  "languages": {
    "Python": {
      "language_servers": [
        // Enable ty, disable basedpyright
        // other registered language servers (ruff, pylsp, pyright).
        "ty",
        "!basedpyright",
        "ruff",
      ],
    },
  },
}
