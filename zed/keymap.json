[
  // ===============================================
  // Normal Mode
  // ===============================================
  {
    "context": "Editor && vim_mode == normal",
    "bindings": {
      // Pane/Workspace management
      "space s": "workspace::Save",
      "space k": "pane::CloseActiveItem",
      "space q": "pane::CloseAllItems",
      "space Q": "workspace::CloseWindow",
      "space space k": "workspace::CloseAllItemsAndPanes",
      "space m": "command_palette::Toggle",
      "space a": "pane::AlternateFile",
      // Navigation
      "space f": "file_finder::Toggle",
      "space e": "project_panel::ToggleFocus",
      "space u t": "workspace::ToggleRightDock",
      "space space l": "projects::OpenRecent",
      // Search
      "space /": "pane::DeploySearch",
      "space *": [
        "action::Sequence",
        ["vim::MoveToNext", "pane::DeploySearch"],
      ],
      // LSP
      "space l g": "editor::Hover",
      "space l f": "editor::Format",
      "space l o": "editor::OrganizeImports",
      "space l h": "editor::ToggleInlayHints",
      "space l s": "project_symbols::Toggle",
      "space d l": "editor::ToggleDiagnostics",
      // Terminal
      "space c s": "terminal_panel::ToggleFocus",
      "space c S": "workspace::NewTerminal",
      // Git
      "space g g": "git_panel::Toggle",
      // Personal
      "space u m": "zed::OpenSettingsFile",
      "space u k": "zed::OpenKeymapFile",
    },
  },
  // ===============================================
  // VIsual Mode
  // ===============================================
  {
    "context": "Editor && vim_mode == visual",
    "bindings": {
      "space *": "pane::DeploySearch",
    },
  },
  // ===============================================
  // Insert Mode
  // ===============================================
  {
    "context": "Editor && vim_mode == insert",
    "bindings": {
      "ctrl-h": "editor::Hover",
    },
  },
  // ===============================================
  // Project Panel
  // ===============================================
  {
    "context": "ProjectPanel && not_editing",
    "bindings": {
      "a": "project_panel::NewFile",
      "A": "project_panel::NewDirectory",
      "r": "project_panel::Rename",
      "d": "project_panel::Delete",
      "x": "project_panel::Cut",
      "y": "project_panel::Copy",
      "p": "project_panel::Paste",
      "ctrl-[": "workspace::ToggleRightDock",
      "space q": "workspace::ToggleRightDock",
      "space e": "editor::ToggleFocus",
      "space u t": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "Pane",
    "bindings": {
      "ctrl-[": ["pane::CloseActiveItem", { "close_pinned": false }],
    },
  },
  {
    "context": "FileFinder",
    "bindings": {
      "ctrl-[": "menu::Cancel",
    },
  },
  {
    "context": "BufferSearchBar && !in_replace",
    "bindings": {
      "ctrl-[": "buffer_search::Dismiss",
    },
  },
]
