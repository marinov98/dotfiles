[core]	
  editor = nvim
  pager = delta

[interactive]
  diffFilter = delta --color-only

[rerere]
  enabled = true

[merge]
  tool = "nvim"
  conflictStyle = zdiff3

[mergetool]
  keepBackup = false
  prompt = false

[mergetool "nvim"]
	cmd = "nvim -d -c \"wincmd l\" -c \"norm ]c\" \"$LOCAL\" \"$MERGED\" \"$REMOTE\""

[delta]
  navigate = true
  dark = true
  line-numbers = true

[pager]
  difftool = true

[diff]
  tool = difftastic

[difftool]
  prompt = false

[difftool "difftastic"]
  cmd = difft "$LOCAL" "$REMOTE"

[color]
	ui = auto

[color "status"]
	added = green bold
	changed = yellow bold
	untracked = red bold

[alias]
  ds = diff --staged
  pb = pull --rebase
  pf = push --force-with-lease
  diffs = -c delta.side-by-side=true diff

[pull]
	ff = only
